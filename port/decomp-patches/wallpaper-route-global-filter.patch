  * inside the 320x240 frame: ((320 - 300*1.10)/2, (240 - 220*1.10)/2). */
 #define PORT_WALLPAPER_MIN_POS_X  (-5.0F)
 #define PORT_WALLPAPER_MIN_POS_Y  (-1.0F)
+
+/* Stage wallpapers go through the sprite library's lbCommonDrawSObjAttr,
+ * which (when the user opted into "Force None" for the 2D filter) would
+ * otherwise force point-filtering on them.  Wallpapers should follow the
+ * global texture-filter CVar like the rest of the 3D scene, so we register
+ * a small bracketing wrapper in place of lbCommonDrawSObjAttr. */
+extern void port_force_2d_filter_push_passthrough(void);
+extern void port_force_2d_filter_pop_passthrough(void);
+static void port_grWallpaperDrawSObjAttr(GObj *gobj)
+{
+    port_force_2d_filter_push_passthrough();
+    lbCommonDrawSObjAttr(gobj);
+    port_force_2d_filter_pop_passthrough();
+}
+#define WALLPAPER_DRAW_CB port_grWallpaperDrawSObjAttr
+#else
+#define WALLPAPER_DRAW_CB lbCommonDrawSObjAttr
 #endif
 

+#ifdef PORT
+/* Stage wallpapers are 300x220 in a 320x240 frame.  The original game
+ * authored them inset by 10 px on every side so the visible image fit
+ * inside the CRT-overscan-safe region (see
+ * docs/bugs/overscan_inset_strip_2026-05-08.md for the parallel
+ * camera/scissor/fade fixes).  On modern flat-panel displays we render
+ * the full 320x240 viewport, which leaves the original 10 px wallpaper
+ * border unfilled (black, sometimes flickering with stale framebuffer
+ * contents on stages whose engine wallpaper doesn't otherwise cover
+ * those pixels).  Enforce a minimum wallpaper zoom large enough to
+ * cover the entire frame even when the camera is fully zoomed out:
+ *
+ *     scale >= max(320/300, 240/220) = max(1.0667, 1.0909) ~= 1.0909
+ *
+ * Round up slightly for a hair of safety against rounding.  The engine
+ * already routinely zooms wallpapers between 1.004x and 2.0x when
+ * players spread out, so this floor is well within the existing
+ * dynamic range and has no observable cost. */
+#define PORT_WALLPAPER_MIN_SCALE  1.10F
+#define PORT_WALLPAPER_NATIVE_W   300.0F
+#define PORT_WALLPAPER_NATIVE_H   220.0F
+/* Centered top-left position for a wallpaper at PORT_WALLPAPER_MIN_SCALE
+ * inside the 320x240 frame: ((320 - 300*1.10)/2, (240 - 220*1.10)/2). */
+#define PORT_WALLPAPER_MIN_POS_X  (-5.0F)
+#define PORT_WALLPAPER_MIN_POS_Y  (-1.0F)
+#endif
+

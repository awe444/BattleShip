tools/ido-recomp/
tools/vpk0cmd
tools/halAssetTool

# Autogenerated — but include/reloc_data.h is now COMMITTED so CI builds
# can run without the ROM. It contains only #defines mapping symbol
# names to small integer IDs; no ROM bytes. Same pattern as
# port/resource/RelocFileTable.cpp, which has been committed since
# inception.
symbols/reloc_data_symbols.*

